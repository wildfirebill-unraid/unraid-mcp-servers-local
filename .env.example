# Unraid MCP Servers Configuration
# Copy to .env and uncomment the variables you need for your setup
# All variables are commented out by default — uncomment only what you need

# Filesystem MCP: root path the server can access
FILESYSTEM_ALLOWED_PATH=/mnt/user

# SQLite MCP: directory containing .db files
#SQLITE_DB_DIR=/mnt/user/data/mcp/sqlite

# Docker MCP: docker socket path
DOCKER_HOST=unix:///var/run/docker.sock

# Media Info/Convert MCP: root path for media files
#MEDIA_INFO_PATH=/mnt/user/data/mcp/media
#MEDIA_CONVERT_PATH=/mnt/user/data/mcp/media/con

# Archive MCP: root path for archive operations
#ARCHIVE_PATH=/mnt/user/data/mcp/archive

# Backup MCP: source and destination directories
BACKUP_SOURCE=/mnt/user/data/mcp/
BACKUP_DEST=/mnt/user/data/mcp/backups

# Finder MCP: root path for file searches
#FINDER_PATH=/mnt/user

# Log MCP: root path for log files
#LOG_PATH=/mnt/user/data/mcp/logs

# CSV MCP: root path for CSV files
#CSV_PATH=/mnt/user/data/mcp/csv

# Template MCP: root path for template files
#TEMPLATE_PATH=/mnt/user/data/mcp/template

# Image MCP: root path for image files
#IMAGE_BASE_PATH=/mnt/user/data/mcp/images

# Encoding MCP: root path for files to analyze
#ENCODING_PATH=/mnt/user

# Git MCP: root path containing git repositories
GIT_BASE_PATH=/mnt/user/data/mcp/git

# MemPalace MCP: palace storage path (persistent vector database)
MEMPALACE_PALACE_PATH=/mnt/user/data/mcp/palace

# === DATA / DOCUMENTS ===
# Barcode MCP: root path for barcode images
#BARCODE_PATH=/mnt/user/data/mcp/barcode

# Cron MCP: root path for cron files
#CRON_MCP_PATH=/mnt/user

# Diff MCP: root path for file diffs
#DIFF_BASE_PATH=/mnt/user

# Envfile MCP: root path for .env files
#ENVFILE_PATH=/mnt/user/data/mcp/env

# Epub MCP: root path for epub files
#EPUB_PATH=/mnt/user/data/mcp/epub

# Excel MCP: root path for Excel files
#EXCEL_PATH=/mnt/user/data/mcp/excel

# Hash MCP: root path for hash files
#HASH_PATH=/mnt/user/data/mcp/hash

# Hexdump MCP: root path for hex dump files
#HEXDUMP_PATH=/mnt/user/data/mcp/hex

# Ini MCP: root path for ini files
#INI_PATH=/mnt/user/data/mcp/ini

# Markdown MCP: root path for markdown files
#MARKDOWN_PATH=/mnt/user/data/mcp/markdown

# Password MCP: root path for password files
#PASSWORD_MCP_PATH=/mnt/user/data/mcp/password

# PDF MCP: root path for PDF files
#PDF_PATH=/mnt/user/data/mcp/pdf

# Properties MCP: root path for properties files
#PROPERTIES_PATH=/mnt/user/data/mcp/properties

# QR Code MCP: root path for QR code images
#QRCODE_PATH=/mnt/user/data/mcp/qr

# Service MCP: root path for service files
#SERVICE_MCP_PATH=/mnt/user/data/mcp/service

# SSL MCP: root path for SSL certificate files
#SSL_BASE_PATH=/mnt/user/data/mcp/ssl

# Temp Dir MCP: root path for temp files
#TEMP_BASE_PATH=/mnt/user/data/mcp/temp

# TOML MCP: root path for TOML files
#TOML_PATH=/mnt/user/data/mcp/toml

# Tree MCP: root path for directory trees
#TREE_PATH=/mnt/user/data/mcp

# UUID MCP: root path for UUID files
#UUID_MCP_PATH=/mnt/user/data/mcp/uuid

# XML MCP: root path for XML files
#XML_BASE_PATH=/mnt/user/data/mcp/xml

# YAML MCP: root path for YAML files
#YAML_BASE_PATH=/mnt/user/data/mcp/yaml

# GeoIP MCP: path to GeoIP databases
#GEOIP_DB_PATH=/mnt/user/data/mcp/geoip
#GEOIP_ASN_DB_PATH=/mnt/user/data/mcp/geoipasn

# === DATABASES / DATA STORES ===
# Elasticsearch MCP: connection settings
#ES_HOST=localhost
#ES_PORT=9200

# InfluxDB MCP: connection settings
#INFLUXDB_URL=http://localhost:8086
#INFLUXDB_TOKEN=
#INFLUXDB_ORG=myorg

# Memcached MCP: connection settings
#MEMCACHED_HOST=localhost
#MEMCACHED_PORT=11211

# MongoDB MCP: connection settings
#MONGODB_URI=mongodb://localhost:27017
#MONGODB_DATABASE=mydb

# MySQL MCP: connection settings
#MYSQL_HOST=localhost
#MYSQL_PORT=3306
#MYSQL_USER=root
#MYSQL_PASSWORD=
#MYSQL_DATABASE=mydb

# PostgreSQL MCP: connection settings (uses standard PG env vars)
#PGHOST=localhost
#PGPORT=5432
#PGUSER=postgres
#PGPASSWORD=
#PGDATABASE=mydb

# Redis MCP: connection settings
#REDIS_HOST=localhost
#REDIS_PORT=6379
#REDIS_PASSWORD=
#REDIS_DB=0

# === EMAIL ===
# Email MCP: SMTP connection settings
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASSWORD=
#SMTP_USE_TLS=true
#SMTP_FROM=noreply@example.com
#EMAIL_PATH=/mnt/user/data/mcp/email

# === MCP GATEWAY ===
# Servers to enable (comma-separated, no spaces). Catalog registers all 106;
# only these get containers spun up.
#GATEWAY_SERVERS=filesystem-mcp,sqlite-mcp,docker-mcp,system-info-mcp,git-mcp,github-mcp,mempalace-mcp

# === WEBHOOK ===
# Webhook MCP: default timeout in seconds
#WEBHOOK_TIMEOUT=30

# === GITHUB ===
# GitHub MCP: personal access token for API access (classic or fine-grained)
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com
